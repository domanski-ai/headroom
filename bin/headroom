#!/usr/bin/env bash
# headroom launcher — runs the package from the repo checkout, no install step.
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do  # resolve symlinks (install.sh links from ~/.local/bin)
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
HEADROOM_REPO="$(cd "$(dirname "$SOURCE")/.." && pwd)"
PYTHON=python3
case "$(uname -s)" in
  CYGWIN*|MINGW*|MSYS*)
    HEADROOM_REPO="$(cygpath -w "$HEADROOM_REPO")"
    PYTHON=python
    ;;
esac
export HEADROOM_REPO
exec "$PYTHON" -c 'import os, sys
sys.path.insert(0, os.environ["HEADROOM_REPO"])
from headroom.__main__ import main
raise SystemExit(main())' "$@"
